    "dialog.cmuxConfig.confirmRestart.message": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "Щ…ШіШ§ШӯШ© Ш§Щ„Ш№Щ…Щ„ ШЁЩҮШ°Ш§ Ш§Щ„Ш§ШіЩ… Щ…ЩҲШ¬ЩҲШҜШ© ШЁШ§Щ„ЩҒШ№Щ„. ЩҮЩ„ ШӘШұЩҠШҜ ШҘШәЩ„Ш§ЩӮЩҮШ§ ЩҲШҘЩҶШҙШ§ШЎ ЩҲШ§ШӯШҜШ© Ш¬ШҜЩҠШҜШ©Шҹ"
          }
        },
        "bs": {
          "stringUnit": {
            "state": "translated",
            "value": "Radni prostor s ovim imenom veДҮ postoji. Zatvoriti ga i kreirati novi?"
