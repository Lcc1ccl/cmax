        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "аёўаёұаёҮа№„аёЎа№Ҳа№„аё”а№үаё•аёұа№үаёҮаёЈаё«аёұаёӘаёңа№ҲаёІаёҷ а№„аё„аёҘа№Җаёӯа№Үаёҷаё•а№Ңаё аёІаёўаёҷаёӯаёҒаёҲаё°аё–аё№аёҒаёҡаёҘа№ҮаёӯаёҒаёҲаёҷаёҒаё§а№ҲаёІаёҲаё°аёҒаёіаё«аёҷаё”аё„а№ҲаёІ"
