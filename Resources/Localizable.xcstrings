    "cli.claude-teams.usage": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Usage: cmux claude-teams [claude-args...]\n\nLaunch Claude Code with agent teams enabled.\n\nThis command:\n  - defaults Claude teammate mode to auto\n  - sets a tmux-like environment so Claude auto mode uses cmux splits\n  - sets CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS=1\n  - prepends a private tmux shim to PATH\n  - forwards all remaining arguments to claude\n\nThe tmux shim translates supported tmux window/pane commands into cmux\nworkspace and split operations in the current cmux session.\n\nExamples:\n  cmux claude-teams\n  cmux claude-teams --continue\n  cmux claude-teams --model sonnet"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "дҪҝгҒ„ж–№: cmux claude-teams [claude-args...]\n\nгӮЁгғјгӮёгӮ§гғігғҲгғҒгғјгғ гӮ’жңүеҠ№гҒ«гҒ—гҒҹзҠ¶ж…ӢгҒ§ Claude Code гӮ’иө·еӢ•гҒ—гҒҫгҒҷгҖӮ\n\nгҒ“гҒ®гӮігғһгғігғүгҒҜж¬ЎгӮ’иЎҢгҒ„гҒҫгҒҷ:\n  - Claude гҒ® teammate mode гӮ’ auto гҒ«иЁӯе®ҡ\n  - Claude гҒ® auto mode гҒҢ cmux гҒ® split гӮ’дҪҝгҒҶгӮҲгҒҶ tmux йўЁгҒ®з’°еўғгӮ’иЁӯе®ҡ\n  - CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS=1 гӮ’иЁӯе®ҡ\n  - е°Ӯз”ЁгҒ® tmux shim гӮ’ PATH гҒ®е…Ҳй ӯгҒ«иҝҪеҠ \n  - ж®ӢгӮҠгҒ®еј•ж•°гӮ’гҒқгҒ®гҒҫгҒҫ claude гҒ«жёЎгҒҷ\n\ntmux shim гҒҜгҖҒеҜҫеҝңгҒ—гҒҰгҒ„гӮӢ tmux гҒ® window/pane гӮігғһгғігғүгӮ’гҖҒзҸҫеңЁгҒ® cmux гӮ»гғғгӮ·гғ§гғіеҶ…гҒ® workspace гҒЁ split ж“ҚдҪңгҒ«еӨүжҸӣгҒ—гҒҫгҒҷгҖӮ\n\nдҫӢ:\n  cmux claude-teams\n  cmux claude-teams --continue\n  cmux claude-teams --model sonnet"
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Р’РёРәРҫСҖРёСҒСӮР°РҪРҪСҸ: cmux claude-teams [Р°СҖРіСғРјРөРҪСӮРё-claude...]\n\nР—Р°РҝСғСҒРә Claude Code Р· СғРІС–РјРәРҪРөРҪРёРјРё РәРҫРјР°РҪРҙР°РјРё Р°РіРөРҪСӮС–РІ.\n\nРҰСҸ РәРҫРјР°РҪРҙР°:\n  - СӮРёРҝРҫРІРҫ РІРјРёРәР°С” СҖРөР¶РёРј teammate РҙР»СҸ Claude\n  - Р·Р°РұРөР·РҝРөСҮСғС” РҝС–РҙСӮСҖРёРјРәСғ cmux РҙР»СҸ СҒРөР°РҪСҒСғ\n  - РІСҒСӮР°РҪРҫРІР»СҺС” CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS=1\n  - РҙРҫРҙР°С” РҝСҖРёРІР°СӮРҪСғ tmux-РҝСҖРҫРәР»Р°РҙРәСғ РҪР° РҝРҫСҮР°СӮРҫРә PATH\n  - РҝРөСҖРөРҙР°С” РІСҒС– С–РҪСҲС– Р°СҖРіСғРјРөРҪСӮРё РҙРҫ claude\n\nTmux-РҝСҖРҫРәР»Р°РҙРәР° РҝРөСҖРөСӮРІРҫСҖСҺС” РҝС–РҙСӮСҖРёРјСғРІР°РҪС– РәРҫРјР°РҪРҙРё tmux РІС–РәРҫРҪ/РҝР°РҪРөР»РөР№ РҪР° РҫРҝРөСҖР°СҶС–С—\nСҖРҫРұРҫСҮРёС… РҝСҖРҫСҒСӮРҫСҖС–РІ С– СҖРҫР·РҙС–Р»С–РІ cmux Сғ РҝРҫСӮРҫСҮРҪРҫРјСғ СҒРөР°РҪСҒС– cmux.\n\nРҹСҖРёРәР»Р°РҙРё:\n  cmux claude-teams\n  cmux claude-teams --continue\n  cmux claude-teams --model sonnet"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "мӮ¬мҡ©лІ•: cmux claude-teams [claude-args...]\n\nм—җмқҙм „нҠё нҢҖмқҙ нҷңм„ұнҷ”лҗң мғҒнғңлЎң Claude CodeлҘј мӢӨн–үн•©лӢҲлӢӨ.\n\nмқҙ лӘ…л №мқҖ:\n  - Claude нҢҖмӣҗ лӘЁл“ңлҘј autoлЎң м„Өм •н•©лӢҲлӢӨ\n  - Claude auto лӘЁл“ңк°Җ cmux л¶„н• мқ„ мӮ¬мҡ©н•ҳлҸ„лЎқ tmux нҳёнҷҳ нҷҳкІҪмқ„ м„Өм •н•©лӢҲлӢӨ\n  - CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS=1мқ„ м„Өм •н•©лӢҲлӢӨ\n  - PATH м•һм—җ м „мҡ© tmux мӢ¬мқ„ м¶”к°Җн•©лӢҲлӢӨ\n  - лӮҳлЁём§Җ мқёмһҗлҘј лӘЁл‘җ claudeм—җ м „лӢ¬н•©лӢҲлӢӨ\n\ntmux мӢ¬мқҖ м§ҖмӣҗлҗҳлҠ” tmux мңҲлҸ„мҡ°/нҢЁмқё лӘ…л №мқ„ нҳ„мһ¬ cmux м„ём…ҳмқҳ\nмӣҢнҒ¬мҠӨнҺҳмқҙмҠӨ л°Ҹ л¶„н•  мһ‘м—…мңјлЎң ліҖнҷҳн•©лӢҲлӢӨ.\n\nмҳҲмӢң:\n  cmux claude-teams\n  cmux claude-teams --continue\n  cmux claude-teams --model sonnet"
          }
        }
      }
    },
    "cli.omo.usage": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Usage: cmux omo [opencode-args...]\n\nLaunch OpenCode with oh-my-openagent in a cmux-aware environment.\n\noh-my-openagent orchestrates multiple AI models as specialized agents in\nparallel. This command sets up a tmux shim so agent panes become native\ncmux splits with sidebar metadata and notifications.\n\nThis command:\n  - sets a tmux-like environment so oh-my-openagent uses cmux splits\n  - prepends a private tmux shim to PATH\n  - forwards all remaining arguments to opencode\n\nThe tmux shim translates tmux window/pane commands into cmux workspace\nand split operations in the current cmux session.\n\nExamples:\n  cmux omo\n  cmux omo --continue\n  cmux omo --model claude-sonnet-4-6"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "дҪҝгҒ„ж–№: cmux omo [opencode-args...]\n\ncmux еҜҫеҝңгҒ®з’°еўғгҒ§ OpenCode гҒЁ oh-my-openagent гӮ’иө·еӢ•гҒ—гҒҫгҒҷгҖӮ\n\noh-my-openagent гҒҜиӨҮж•°гҒ® AI гғўгғҮгғ«гӮ’е°Ӯй–ҖгӮЁгғјгӮёгӮ§гғігғҲгҒЁгҒ—гҒҰдёҰеҲ—гҒ«\nгӮӘгғјгӮұгӮ№гғҲгғ¬гғјгӮ·гғ§гғігҒ—гҒҫгҒҷгҖӮгҒ“гҒ®гӮігғһгғігғүгҒҜ tmux shim гӮ’иЁӯе®ҡгҒ—гҖҒ\nгӮЁгғјгӮёгӮ§гғігғҲгҒ®гғҡгӮӨгғігӮ’гғҚгӮӨгғҶгӮЈгғ–гҒ® cmux split гҒ«еӨүжҸӣгҒ—гҒҫгҒҷгҖӮ\n\nгҒ“гҒ®гӮігғһгғігғүгҒҜж¬ЎгӮ’иЎҢгҒ„гҒҫгҒҷ:\n  - oh-my-openagent гҒҢ cmux гҒ® split гӮ’дҪҝгҒҶгӮҲгҒҶ tmux йўЁгҒ®з’°еўғгӮ’иЁӯе®ҡ\n  - е°Ӯз”ЁгҒ® tmux shim гӮ’ PATH гҒ®е…Ҳй ӯгҒ«иҝҪеҠ \n  - ж®ӢгӮҠгҒ®еј•ж•°гӮ’гҒқгҒ®гҒҫгҒҫ opencode гҒ«жёЎгҒҷ\n\ntmux shim гҒҜгҖҒtmux гҒ® window/pane гӮігғһгғігғүгӮ’гҖҒзҸҫеңЁгҒ® cmux гӮ»гғғгӮ·гғ§гғіеҶ…гҒ®\nworkspace гҒЁ split ж“ҚдҪңгҒ«еӨүжҸӣгҒ—гҒҫгҒҷгҖӮ\n\nдҫӢ:\n  cmux omo\n  cmux omo --continue\n  cmux omo --model claude-sonnet-4-6"
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Р’РёРәРҫСҖРёСҒСӮР°РҪРҪСҸ: cmux omo [Р°СҖРіСғРјРөРҪСӮРё-opencode...]\n\nР—Р°РҝСғСҒРә OpenCode Р· oh-my-openagent Сғ СҒРөСҖРөРҙРҫРІРёСүС– cmux.\n\noh-my-openagent РҫСҖРәРөСҒСӮСҖСғС” РәС–Р»СҢРәР° РјРҫРҙРөР»РөР№ РЁРҶ СҸРә СҒРҝРөСҶС–Р°Р»С–Р·РҫРІР°РҪРёС… Р°РіРөРҪСӮС–РІ\nРҝР°СҖР°Р»РөР»СҢРҪРҫ. РҰСҸ РәРҫРјР°РҪРҙР° РҪР°Р»Р°СҲСӮРҫРІСғС” tmux-РҝСҖРҫРәР»Р°РҙРәСғ, СүРҫРұ РҝР°РҪРөР»С– Р°РіРөРҪСӮС–РІ\nСҒСӮР°Р»Рё РҪР°СӮРёРІРҪРёРјРё СҖРҫР·РҙС–Р»Р°РјРё cmux Р· РјРөСӮР°РҙР°РҪРёРјРё РұС–СҮРҪРҫС— РҝР°РҪРөР»С– СӮР° СҒРҝРҫРІС–СүРөРҪРҪСҸРјРё.\n\nРҰСҸ РәРҫРјР°РҪРҙР°:\n  - Р·Р°РұРөР·РҝРөСҮСғС” РҝС–РҙСӮСҖРёРјРәСғ cmux РҙР»СҸ oh-my-openagent\n  - РҙРҫРҙР°С” РҝСҖРёРІР°СӮРҪСғ tmux-РҝСҖРҫРәР»Р°РҙРәСғ РҪР° РҝРҫСҮР°СӮРҫРә PATH\n  - РҝРөСҖРөРҙР°С” РІСҒС– С–РҪСҲС– Р°СҖРіСғРјРөРҪСӮРё РҙРҫ opencode\n\nTmux-РҝСҖРҫРәР»Р°РҙРәР° РҝРөСҖРөСӮРІРҫСҖСҺС” РәРҫРјР°РҪРҙРё tmux РІС–РәРҫРҪ/РҝР°РҪРөР»РөР№ РҪР° РҫРҝРөСҖР°СҶС–С—\nСҖРҫРұРҫСҮРёС… РҝСҖРҫСҒСӮРҫСҖС–РІ С– СҖРҫР·РҙС–Р»С–РІ cmux Сғ РҝРҫСӮРҫСҮРҪРҫРјСғ СҒРөР°РҪСҒС– cmux.\n\nРҹСҖРёРәР»Р°РҙРё:\n  cmux omo\n  cmux omo --continue\n  cmux omo --model claude-sonnet-4-6"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "мӮ¬мҡ©лІ•: cmux omo [opencode-args...]\n\ncmux нҳёнҷҳ нҷҳкІҪм—җм„ң oh-my-openagentмҷҖ н•Ёк»ҳ OpenCodeлҘј мӢӨн–үн•©лӢҲлӢӨ.\n\noh-my-openagentлҠ” м—¬лҹ¬ AI лӘЁлҚёмқ„ м „л¬ё м—җмқҙм „нҠёлЎң лі‘л ¬ мЎ°мңЁн•©лӢҲлӢӨ.\nмқҙ лӘ…л №мқҖ м—җмқҙм „нҠё нҢЁмқёмқҙ мӮ¬мқҙл“ңл°” л©”нғҖлҚ°мқҙн„°мҷҖ м•ҢлҰјмқҙ мһҲлҠ”\nл„ӨмқҙнӢ°лёҢ cmux л¶„н• мқҙ лҗҳлҸ„лЎқ tmux мӢ¬мқ„ м„Өм •н•©лӢҲлӢӨ.\n\nмқҙ лӘ…л №мқҖ:\n  - oh-my-openagentк°Җ cmux л¶„н• мқ„ мӮ¬мҡ©н•ҳлҸ„лЎқ tmux нҳёнҷҳ нҷҳкІҪмқ„ м„Өм •н•©лӢҲлӢӨ\n  - PATH м•һм—җ м „мҡ© tmux мӢ¬мқ„ м¶”к°Җн•©лӢҲлӢӨ\n  - лӮҳлЁём§Җ мқёмһҗлҘј лӘЁл‘җ opencodeм—җ м „лӢ¬н•©лӢҲлӢӨ\n\ntmux мӢ¬мқҖ tmux мңҲлҸ„мҡ°/нҢЁмқё лӘ…л №мқ„ нҳ„мһ¬ cmux м„ём…ҳмқҳ\nмӣҢнҒ¬мҠӨнҺҳмқҙмҠӨ л°Ҹ л¶„н•  мһ‘м—…мңјлЎң ліҖнҷҳн•©лӢҲлӢӨ.\n\nмҳҲмӢң:\n  cmux omo\n  cmux omo --continue\n  cmux omo --model claude-sonnet-4-6"
          }
        }
      }
    },
