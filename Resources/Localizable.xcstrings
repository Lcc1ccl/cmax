        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "РҡРөСҖСғС” РҙРҫСҒСӮСғРҝРҫРј РҙРҫ Р»РҫРәР°Р»СҢРҪРҫРіРҫ Unix-СҒРҫРәРөСӮР° РҙР»СҸ РҝСҖРҫРіСҖР°РјРҪРҫРіРҫ РәРҫРҪСӮСҖРҫР»СҺ. Р’РёРұРөСҖС–СӮСҢ СҖРөР¶РёРј РІС–РҙРҝРҫРІС–РҙРҪРҫ РҙРҫ РІР°СҲРҫС— РјРҫРҙРөР»С– Р·Р°РіСҖРҫР·."
