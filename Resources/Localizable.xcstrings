        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "аёӘаёөаё—аёөа№ҲаёҒаёіаё«аёҷаё”а№ҖаёӯаёҮ: аёўаёұаёҮа№„аёЎа№ҲаёЎаёө а№ғаёҠа№ү \"а№ҖаёҘаё·аёӯаёҒаёӘаёөаё—аёөа№ҲаёҒаёіаё«аёҷаё”а№ҖаёӯаёҮ...\" аёҲаёІаёҒа№ҖаёЎаёҷаё№аёҡаёЈаёҙаёҡаё—а№Җаё§аёҙаёЈа№ҢаёҒаёӘа№ҖаёӣаёӢ"
