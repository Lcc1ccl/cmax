        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "кі м •лҗң мӣҢнҒ¬мҠӨнҺҳмқҙмҠӨлҠ” кі м •лҗң мғҒнғңм—җм„ң лӢ«мқ„ мҲҳ м—ҶмҠөлӢҲлӢӨ. лЁјм Җ мӣҢнҒ¬мҠӨнҺҳмқҙмҠӨмқҳ кі м •мқ„ н•ҙм ңн•ҳм„ёмҡ”."
