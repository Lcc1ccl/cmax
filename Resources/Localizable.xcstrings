        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "иӯҰе‘Ҡ: гғ•гғ«гӮӘгғјгғ—гғігӮўгӮҜгӮ»гӮ№гҒ«гҒҷгӮӢгҒЁгҖҒгҒ“гҒ®MacдёҠгҒ®еҲ¶еҫЎгӮҪгӮұгғғгғҲгҒҢиӘ°гҒ§гӮӮиӘӯгҒҝжӣёгҒҚеҸҜиғҪгҒ«гҒӘгӮҠгҖҒиӘҚиЁјгғҒгӮ§гғғгӮҜгҒҢз„ЎеҠ№гҒ«гҒӘгӮҠгҒҫгҒҷгҖӮгғӯгғјгӮ«гғ«гғҮгғҗгғғгӮ°з”ЁйҖ”гҒ«гҒ®гҒҝдҪҝз”ЁгҒ—гҒҰгҒҸгҒ гҒ•гҒ„гҖӮ"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "иӯҰе‘Ҡпјҡе®Ңе…ЁејҖж”ҫи®ҝй—®е°ҶдҪҝжҺ§еҲ¶еҘ—жҺҘеӯ—еңЁжӯӨ Mac дёҠеҜ№жүҖжңүз”ЁжҲ·еҸҜиҜ»/еҸҜеҶҷпјҢе№¶зҰҒз”Ёиә«д»ҪйӘҢиҜҒжЈҖжҹҘгҖӮд»…з”ЁдәҺжң¬ең°и°ғиҜ•гҖӮ"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "иӯҰе‘Ҡпјҡе®Ңе…Ёй–Ӣж”ҫеӯҳеҸ–жңғи®“жҺ§еҲ¶ Socket еңЁжӯӨ Mac дёҠеҸҜиў«жүҖжңүдәәи®ҖеҜ«пјҢдёҰеҒңз”Ёй©—иӯүжӘўжҹҘгҖӮеғ…дҫӣжң¬ж©ҹйҷӨйҢҜдҪҝз”ЁгҖӮ"
