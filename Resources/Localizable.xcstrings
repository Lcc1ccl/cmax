    "settings.browser.externalPatterns.subtitle": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Applies to terminal link clicks and intercepted `open https://...` calls. One rule per line. Plain text matches any URL substring, or prefix with `re:` for regex (for example: openai.com/usage, re:^https?://[^/]*\\\\.example\\\\.com/(billing|usage))."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "гӮҝгғјгғҹгғҠгғ«гҒ®гғӘгғігӮҜгӮҜгғӘгғғгӮҜгҒҠгӮҲгҒігӮӨгғігӮҝгғјгӮ»гғ—гғҲгҒ•гӮҢгҒҹ`open https://...`е‘јгҒіеҮәгҒ—гҒ«йҒ©з”ЁгҒ•гӮҢгҒҫгҒҷгҖӮ1иЎҢгҒ«1гғ«гғјгғ«гҖӮгғ—гғ¬гғјгғігғҶгӮӯгӮ№гғҲгҒҜURLйғЁеҲҶж–Үеӯ—еҲ—гҒ«дёҖиҮҙгҒ—гҖҒ`re:`гғ—гғ¬гғ•гӮЈгғғгӮҜгӮ№гҒ§жӯЈиҰҸиЎЁзҸҫгӮ’дҪҝз”ЁгҒ§гҒҚгҒҫгҒҷпјҲдҫӢ: openai.com/usage, re:^https?://[^/]*\\\\.example\\\\.com/(billing|usage)пјүгҖӮ"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "йҖӮз”ЁдәҺз»Ҳз«Ҝдёӯзҡ„й“ҫжҺҘзӮ№еҮ»е’ҢжӢҰжҲӘзҡ„ `open https://...` и°ғз”ЁгҖӮжҜҸиЎҢдёҖжқЎи§„еҲҷгҖӮзәҜж–Үжң¬еҢ№й…Қд»»ж„Ҹ URL еӯҗдёІпјҢжҲ–дҪҝз”Ё `re:` еүҚзјҖиЎЁзӨәжӯЈеҲҷиЎЁиҫҫејҸпјҲдҫӢеҰӮпјҡopenai.com/usageгҖҒre:^https?://[^/]*\\\\.example\\\\.com/(billing|usage)пјүгҖӮ"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "еҘ—з”Ёж–јзөӮз«Ҝж©ҹйҖЈзөҗй»һж“Ҡе’Ңж””жҲӘзҡ„ `open https://...` е‘јеҸ«гҖӮжҜҸиЎҢдёҖжўқиҰҸеүҮгҖӮзҙ”ж–Үеӯ—жңғжҜ”е°Қ URL зҡ„д»»дҪ•еӯҗеӯ—дёІпјҢжҲ–еҠ дёҠ `re:` еүҚз¶ҙдҪҝз”ЁжӯЈиҰҸиЎЁзӨәејҸпјҲдҫӢеҰӮпјҡopenai.com/usageгҖҒre:^https?://[^/]*\\\\.example\\\\.com/(billing|usage)пјүгҖӮ"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "н„°лҜёл„җ л§ҒнҒ¬ нҒҙлҰӯ л°Ҹ мқён„°м…үнҠёлҗң `open https://...` нҳём¶ңм—җ м Ғмҡ©лҗ©лӢҲлӢӨ. н•ң мӨ„м—җ н•ҳлӮҳмқҳ к·ңм№ҷ. мқјл°ҳ н…ҚмҠӨнҠёлҠ” URLмқҳ н•ҳмң„ л¬ёмһҗм—ҙмқ„ мқјм№ҳмӢңнӮӨл©°, `re:` м ‘л‘җмӮ¬лЎң м •к·ңмӢқмқ„ мӮ¬мҡ©н•  мҲҳ мһҲмҠөлӢҲлӢӨ (мҳҲ: openai.com/usage, re:^https?://[^/]*\\\\.example\\\\.com/(billing|usage))."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Gilt fГјr Klicks auf Terminal-Links und abgefangene `open https://...`-Aufrufe. Eine Regel pro Zeile. Klartext stimmt mit jedem URL-Teilstring Гјberein, oder verwenden Sie das PrГӨfix `re:` fГјr Regex (zum Beispiel: openai.com/usage, re:^https?://[^/]*\\\\.example\\\\.com/(billing|usage))."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Se aplica a clics en enlaces del terminal y llamadas interceptadas de `open https://...`. Una regla por lГӯnea. El texto plano coincide con cualquier subcadena de URL, o usa el prefijo `re:` para regex (por ejemplo: openai.com/usage, re:^https?://[^/]*\\\\.example\\\\.com/(billing|usage))."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "S'applique aux clics sur les liens du terminal et aux appels `open https://...` interceptГ©s. Une rГЁgle par ligne. Le texte brut correspond Г  toute sous-chaГ®ne d'URL, ou prГ©fixez par `re:` pour une expression rГ©guliГЁre (par exemple : openai.com/usage, re:^https?://[^/]*\\\\.example\\\\.com/(billing|usage))."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Si applica ai clic sui link nel terminale e alle chiamate intercettate `open https://...`. Una regola per riga. Il testo semplice corrisponde a qualsiasi sottostringa dell'URL, oppure usa il prefisso `re:` per le regex (ad esempio: openai.com/usage, re:^https?://[^/]*\\\\.example\\\\.com/(billing|usage))."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "GГҰlder for terminallinksklik og opfangede `open https://...`-kald. Гүn regel pr. linje. Almindelig tekst matcher enhver URL-delstreng, eller brug `re:` som prГҰfiks for regex (f.eks.: openai.com/usage, re:^https?://[^/]*\\.example\\.com/(billing|usage))."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Dotyczy klikniДҷДҮ linkГіw w terminalu i przechwyconych wywoЕӮaЕ„ `open https://...`. Jedna reguЕӮa na wiersz. ZwykЕӮy tekst dopasowuje dowolny fragment URL, lub uЕјyj prefiksu `re:` dla wyraЕјeЕ„ regularnych (na przykЕӮad: openai.com/usage, re:^https?://[^/]*\\\\.example\\\\.com/(billing|usage))."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "РҹСҖРёРјРөРҪСҸРөСӮСҒСҸ Рә РҪР°Р¶Р°СӮРёСҸРј РҪР° СҒСҒСӢР»РәРё РІ СӮРөСҖРјРёРҪР°Р»Рө Рё РҝРөСҖРөС…РІР°СҮРөРҪРҪСӢРј РІСӢР·РҫРІР°Рј `open https://...`. РһРҙРҪРҫ РҝСҖР°РІРёР»Рҫ РҪР° СҒСӮСҖРҫРәСғ. РһРұСӢСҮРҪСӢР№ СӮРөРәСҒСӮ СҒРҫРІРҝР°РҙР°РөСӮ СҒ Р»СҺРұРҫР№ РҝРҫРҙСҒСӮСҖРҫРәРҫР№ URL, РёР»Рё РёСҒРҝРҫР»СҢР·СғР№СӮРө РҝСҖРөС„РёРәСҒ `re:` РҙР»СҸ СҖРөРіСғР»СҸСҖРҪСӢС… РІСӢСҖР°Р¶РөРҪРёР№ (РҪР°РҝСҖРёРјРөСҖ: openai.com/usage, re:^https?://[^/]*\\\\.example\\\\.com/(billing|usage))."
          }
        },
        "bs": {
          "stringUnit": {
            "state": "translated",
            "value": "Primjenjuje se na klikove linkova u terminalu i presretnute `open https://...` pozive. Jedno pravilo po redu. ObiДҚan tekst odgovara bilo kojem dijelu URL-a, ili dodajte prefiks `re:` za regex (na primjer: openai.com/usage, re:^https?://[^/]*\\\\.example\\\\.com/(billing|usage))."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "ЩҠЩҶШ·ШЁЩӮ Ш№Щ„Щү ЩҶЩӮШұШ§ШӘ Ш§Щ„ШұЩҲШ§ШЁШ· ЩҒЩҠ Ш§Щ„Ш·ШұЩҒЩҠШ© ЩҲШ§ШіШӘШҜШ№Ш§ШЎШ§ШӘ `open https://...` Ш§Щ„Щ…Ш№ШӘШұШ¶Ш©. ЩӮШ§Ш№ШҜШ© ЩҲШ§ШӯШҜШ© Щ„ЩғЩ„ ШіШ·Шұ. Ш§Щ„ЩҶШө Ш§Щ„Ш№Ш§ШҜЩҠ ЩҠШ·Ш§ШЁЩӮ ШЈЩҠ Ш¬ШІШЎ Щ…ЩҶ URLШҢ ШЈЩҲ Ш§ШЁШҜШЈ ШЁЩҖ `re:` Щ„Щ„ШӘШ№ШЁЩҠШұШ§ШӘ Ш§Щ„ЩҶЩ…Ш·ЩҠШ© (Щ…Ш«Ш§Щ„: openai.com/usage, re:^https?://[^/]*\\\\.example\\\\.com/(billing|usage))."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Gjelder for terminallenkeklikk og avlyttede `open https://...`-kall. Гүn regel per linje. Ren tekst matcher enhver del av URL-en, eller prefiks med `re:` for regulГҰre uttrykk (for eksempel: openai.com/usage, re:^https?://[^/]*\\\\.example\\\\.com/(billing|usage))."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Aplica-se a cliques em links do terminal e chamadas interceptadas de `open https://...`. Uma regra por linha. Texto simples corresponde a qualquer substring de URL, ou prefixe com `re:` para regex (por exemplo: openai.com/usage, re:^https?://[^/]*\\\\.example\\\\.com/(billing|usage))."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "а№ғаёҠа№үаёҒаёұаёҡаёҒаёІаёЈаё„аёҘаёҙаёҒаёҘаёҙаёҮаёҒа№Ңа№ғаёҷа№Җаё—аёӯаёЈа№ҢаёЎаёҙаёҷаёұаёҘа№ҒаёҘаё°аёҒаёІаёЈаё”аёұаёҒаёҲаёұаёҡаё„аёіаёӘаёұа№ҲаёҮ `open https://...` аёҒаёҺаё«аёҷаё¶а№ҲаёҮаёӮа№үаёӯаё•а№ҲаёӯаёҡаёЈаёЈаё—аёұаё” аёӮа№үаёӯаё„аё§аёІаёЎаёҳаёЈаёЈаёЎаё”аёІаёҲаё°аёҲаёұаёҡаё„аё№а№ҲаёҒаёұаёҡаёӘа№Ҳаё§аёҷа№ғаё”аёҒа№Үа№„аё”а№үаёӮаёӯаёҮ URL аё«аёЈаё·аёӯаёҷаёіаё«аёҷа№үаёІаё”а№үаё§аёў `re:` аёӘаёіаё«аёЈаёұаёҡ regex (аё•аёұаё§аёӯаёўа№ҲаёІаёҮ: openai.com/usage, re:^https?://[^/]*\\\\.example\\\\.com/(billing|usage))"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Terminal baДҹlantДұ tДұklamalarДұna ve yakalanan `open https://...` Г§aДҹrДұlarДұna uygulanДұr. SatДұr baЕҹДұna bir kural. DГјz metin herhangi bir URL alt dizesiyle eЕҹleЕҹir veya regex iГ§in `re:` Г¶n ekini kullanДұn (Г¶rneДҹin: openai.com/usage, re:^https?://[^/]*\\\\.example\\\\.com/(billing|usage))."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Р—Р°СҒСӮРҫСҒРҫРІСғС”СӮСҢСҒСҸ РҙРҫ РәР»С–РәС–РІ РҪР° РҝРҫСҒРёР»Р°РҪРҪСҸ РІ СӮРөСҖРјС–РҪР°Р»С– СӮР° РҝРөСҖРөС…РҫРҝР»РөРҪРёС… РІРёРәР»РёРәС–РІ `open https://...`. РһРҙРҪРө РҝСҖР°РІРёР»Рҫ РҪР° СҖСҸРҙРҫРә. Р—РІРёСҮР°Р№РҪРёР№ СӮРөРәСҒСӮ Р·РұС–РіР°С”СӮСҢСҒСҸ Р· РұСғРҙСҢ-СҸРәРҫСҺ СҮР°СҒСӮРёРҪРҫСҺ URL, Р°РұРҫ РҙРҫРҙР°Р№СӮРө РҝСҖРөС„С–РәСҒ `re:` РҙР»СҸ СҖРөРіСғР»СҸСҖРҪРҫРіРҫ РІРёСҖР°Р·Сғ (РҪР°РҝСҖРёРәР»Р°Рҙ: openai.com/usage, re:^https?://[^/]*\\.example\\.com/(billing|usage))."
          }
        }
      }
