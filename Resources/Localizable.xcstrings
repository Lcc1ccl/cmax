        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ein Arbeitsbereich mit diesem Namen existiert bereits. SchlieГҹen und neu erstellen?"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A workspace with this name already exists. Close it and create a new one?"
          }
