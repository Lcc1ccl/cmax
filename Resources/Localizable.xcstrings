    "about.description": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A Ghostty-based terminal with vertical tabs\nand a notification panel for macOS."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "GhosttyгғҷгғјгӮ№гҒ®зёҰгӮҝгғ–д»ҳгҒҚгӮҝгғјгғҹгғҠгғ«гҒЁ\nmacOSз”ЁйҖҡзҹҘгғ‘гғҚгғ«гҖӮ"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "еҹәдәҺ Ghostty зҡ„ macOS з»Ҳз«ҜпјҢ\nж”ҜжҢҒеһӮзӣҙж ҮзӯҫйЎөе’ҢйҖҡзҹҘйқўжқҝгҖӮ"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "еҹәж–ј Ghostty зҡ„ macOS зөӮз«Ҝж©ҹпјҢ\nе…·еӮҷеһӮзӣҙжЁҷзұӨй ҒиҲҮйҖҡзҹҘйқўжқҝгҖӮ"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "м„ёлЎң нғӯкіј м•ҢлҰј нҢЁл„җмқ„ к°–м¶ҳ\nGhostty кё°л°ҳ macOS н„°лҜёл„җ."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ein Ghostty-basiertes Terminal mit vertikalen Tabs\nund einem Benachrichtigungsfeld fГјr macOS."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Un terminal basado en Ghostty con pestaГұas verticales\ny un panel de notificaciones para macOS."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Un terminal basГ© sur Ghostty avec des onglets verticaux\net un panneau de notifications pour macOS."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Un terminale basato su Ghostty con schede verticali\ne un pannello notifiche per macOS."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "En Ghostty-baseret terminal med lodrette faner\nog et notifikationspanel til macOS."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Terminal oparty na Ghostty z pionowymi kartami\ni panelem powiadomieЕ„ dla macOS."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "РўРөСҖРјРёРҪР°Р» РҪР° РұР°Р·Рө Ghostty СҒ РІРөСҖСӮРёРәР°Р»СҢРҪСӢРјРё РІРәР»Р°РҙРәР°РјРё\nРё РҝР°РҪРөР»СҢСҺ СғРІРөРҙРҫРјР»РөРҪРёР№ РҙР»СҸ macOS."
          }
        },
        "bs": {
          "stringUnit": {
            "state": "translated",
            "value": "Terminal zasnovan na Ghostty sa vertikalnim tabovima\ni panelom za obavjeЕЎtenja za macOS."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "Ш·ШұЩҒЩҠШ© Щ…ШЁЩҶЩҠШ© Ш№Щ„Щү Ghostty Щ…Ш№ ШЈЩ„ШіЩҶШ© Ш№Щ…ЩҲШҜЩҠШ©\nЩҲЩ„ЩҲШӯШ© ШҘШҙШ№Ш§ШұШ§ШӘ Щ„ЩҶШёШ§Щ… macOS."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "En Ghostty-basert terminal med vertikale faner\nog et varselpanel for macOS."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Um terminal baseado no Ghostty com abas verticais\ne um painel de notificaГ§Гөes para macOS."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "а№Җаё—аёӯаёЈа№ҢаёЎаёҙаёҷаёұаёҘаёҡаёҷ Ghostty аёһаёЈа№үаёӯаёЎа№Ғаё—а№Үаёҡа№Ғаёҷаё§аё•аёұа№үаёҮ\nа№ҒаёҘаё°а№ҒаёңаёҮаёҒаёІаёЈа№ҒаёҲа№үаёҮа№Җаё•аё·аёӯаёҷаёӘаёіаё«аёЈаёұаёҡ macOS"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "macOS iГ§in dikey sekmeli ve bildirim panelli\nGhostty tabanlДұ terminal."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "РўРөСҖРјС–РҪР°Р» РҪР° РҫСҒРҪРҫРІС– Ghostty Р· РІРөСҖСӮРёРәР°Р»СҢРҪРёРјРё РІРәР»Р°РҙРәР°РјРё\nСӮР° РҝР°РҪРөР»Р»СҺ СҒРҝРҫРІС–СүРөРҪСҢ РҙР»СҸ macOS."
