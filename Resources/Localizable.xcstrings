        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Р’РҪРёРјР°РҪРёРө: РҝРҫР»РҪСӢР№ РҫСӮРәСҖСӢСӮСӢР№ РҙРҫСҒСӮСғРҝ РҙРөР»Р°РөСӮ СғРҝСҖР°РІР»СҸСҺСүРёР№ СҒРҫРәРөСӮ РҙРҫСҒСӮСғРҝРҪСӢРј РҙР»СҸ СҮСӮРөРҪРёСҸ Рё Р·Р°РҝРёСҒРё РІСҒРөРј РҝРҫР»СҢР·РҫРІР°СӮРөР»СҸРј РҪР° СҚСӮРҫРј Mac Рё РҫСӮРәР»СҺСҮР°РөСӮ РҝСҖРҫРІРөСҖРәСғ Р°РІСӮРҫСҖРёР·Р°СҶРёРё. РҳСҒРҝРҫР»СҢР·СғР№СӮРө СӮРҫР»СҢРәРҫ РҙР»СҸ Р»РҫРәР°Р»СҢРҪРҫР№ РҫСӮР»Р°РҙРәРё."
          }
        },
        "bs": {
          "stringUnit": {
            "state": "translated",
            "value": "Upozorenje: Potpuni otvoreni pristup ДҚini kontrolnu utiДҚnicu ДҚitljivom/zapisivom za sve na ovom Macu i onemoguДҮava provjere autentikacije. Koristite samo za lokalno debugiranje."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "ШӘШӯШ°ЩҠШұ: Ш§Щ„ЩҲШөЩҲЩ„ Ш§Щ„Щ…ЩҒШӘЩҲШӯ Ш§Щ„ЩғШ§Щ…Щ„ ЩҠШ¬Ш№Щ„ Щ…ЩӮШЁШі Ш§Щ„ШӘШӯЩғЩ… ЩӮШ§ШЁЩ„Ш§ЩӢ Щ„Щ„ЩӮШұШ§ШЎШ© ЩҲШ§Щ„ЩғШӘШ§ШЁШ© Щ…ЩҶ Ш§Щ„Ш¬Щ…ЩҠШ№ Ш№Щ„Щү ЩҮШ°Ш§ Ш§Щ„ЩҖ Mac ЩҲЩҠШ№Ш·Щ„ ЩҒШӯЩҲШөШ§ШӘ Ш§Щ„Щ…ШөШ§ШҜЩӮШ©. Ш§ШіШӘШ®ШҜЩ… ЩҒЩӮШ· Щ„ШЈШәШұШ§Ш¶ Ш§Щ„ШӘШөШӯЩҠШӯ Ш§Щ„Щ…ШӯЩ„ЩҠ."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Advarsel: Full ГҘpen tilgang gjГёr kontrollsocketen lese-/skrivbar for alle pГҘ denne Mac-en og deaktiverer autentiseringskontroller. Bruk kun for lokal feilsГёking."
