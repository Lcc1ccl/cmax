        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "иӘҚиЁјгҒӘгҒ—гҒ§д»»ж„ҸгҒ®гғӯгғјгӮ«гғ«гғ—гғӯгӮ»гӮ№гҒҠгӮҲгҒігғҰгғјгӮ¶гғјгҒ®жҺҘз¶ҡгӮ’иЁұеҸҜгҒ—гҒҫгҒҷгҖӮе®үе…ЁгҒ§гҒҜгҒӮгӮҠгҒҫгҒӣгӮ“гҖӮ"
