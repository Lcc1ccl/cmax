        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Dostosuj paletДҷ kolorГіw przestrzeni roboczej uЕјywanД… przez Pasek boczny > Kolor przestrzeni roboczej. Wpisy вҖһWybierz wЕӮasny kolorвҖҰвҖқ sД… zapisywane poniЕјej."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "РқР°СҒСӮСҖРҫР№СӮРө РҝР°Р»РёСӮСҖСғ СҶРІРөСӮРҫРІ СҖР°РұРҫСҮРёС… РҝСҖРҫСҒСӮСҖР°РҪСҒСӮРІ, РёСҒРҝРҫР»СҢР·СғРөРјСғСҺ РІ Р‘РҫРәРҫРІР°СҸ РҝР°РҪРөР»СҢ > РҰРІРөСӮ СҖР°РұРҫСҮРөРіРҫ РҝСҖРҫСҒСӮСҖР°РҪСҒСӮРІР°. Р—Р°РҝРёСҒРё В«Р’СӢРұСҖР°СӮСҢ РҝРҫР»СҢР·РҫРІР°СӮРөР»СҢСҒРәРёР№ СҶРІРөСӮ...В» СҒРҫС…СҖР°РҪСҸСҺСӮСҒСҸ РҪРёР¶Рө."
          }
        },
        "bs": {
          "stringUnit": {
            "state": "translated",
            "value": "Prilagodite paletu boja radnog prostora koju koristi BoДҚna traka > Boja radnog prostora. Unosi \"Odaberi prilagoД‘enu boju...\" su trajno saДҚuvani ispod."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "ШӘШ®ШөЩҠШө Щ„ЩҲШӯШ© ШЈЩ„ЩҲШ§ЩҶ Щ…ШіШ§ШӯШ© Ш§Щ„Ш№Щ…Щ„ Ш§Щ„Щ…ШіШӘШ®ШҜЩ…Ш© ШЁЩҲШ§ШіШ·Ш© Ш§Щ„ШҙШұЩҠШ· Ш§Щ„Ш¬Ш§ЩҶШЁЩҠ > Щ„ЩҲЩҶ Щ…ШіШ§ШӯШ© Ш§Щ„Ш№Щ…Щ„. ШҘШҜШ®Ш§Щ„Ш§ШӘ \"Ш§Ш®ШӘЩҠШ§Шұ Щ„ЩҲЩҶ Щ…Ш®ШөШө...\" ШӘЩҸШӯЩҒШё ШЈШҜЩҶШ§ЩҮ."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Tilpass arbeidsomrГҘdefargepaletten som brukes av Sidepanel > ArbeidsomrГҘdefarge. В«Velg egendefinert farge ...В»-oppfГёringer lagres nedenfor."
          }
