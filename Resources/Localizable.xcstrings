        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "гғ‘гӮ№гғҜгғјгғүгҒҢиЁӯе®ҡгҒ•гӮҢгҒҰгҒ„гҒҫгҒӣгӮ“гҖӮиЁӯе®ҡгҒҷгӮӢгҒҫгҒ§еӨ–йғЁгӮҜгғ©гӮӨгӮўгғігғҲгҒҜгғ–гғӯгғғгӮҜгҒ•гӮҢгҒҫгҒҷгҖӮ"
