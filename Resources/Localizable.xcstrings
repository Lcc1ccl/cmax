    "sidebar.workspace.accessibilityHint": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Activate to focus this workspace. Drag to reorder, or use Move Up and Move Down actions."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "гӮўгӮҜгғҶгӮЈгғ–гҒ«гҒ—гҒҰгҒ“гҒ®гғҜгғјгӮҜгӮ№гғҡгғјгӮ№гҒ«гғ•гӮ©гғјгӮ«гӮ№гҒ—гҒҫгҒҷгҖӮгғүгғ©гғғгӮ°гҒ§дёҰгҒ№жӣҝгҒҲгҖҒгҒҫгҒҹгҒҜгҖҢдёҠгҒ«з§»еӢ•гҖҚгҖҢдёӢгҒ«з§»еӢ•гҖҚгӮўгӮҜгӮ·гғ§гғігӮ’дҪҝз”ЁгҒ—гҒҫгҒҷгҖӮ"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "жҝҖжҙ»д»ҘиҒҡз„ҰжӯӨе·ҘдҪңеҢәгҖӮжӢ–жӢҪд»ҘйҮҚж–°жҺ’еәҸпјҢжҲ–дҪҝз”ЁдёҠз§»е’ҢдёӢз§»ж“ҚдҪңгҖӮ"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "е•ҹз”Ёд»ҘиҒҡз„ҰжӯӨе·ҘдҪңеҚҖгҖӮжӢ–жӣід»ҘйҮҚж–°жҺ’еәҸпјҢжҲ–дҪҝз”ЁдёҠз§»е’ҢдёӢз§»еӢ•дҪңгҖӮ"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "мқҙ мһ‘м—… кіөк°„м—җ нҸ¬м»ӨмҠӨн•ҳл Өл©ҙ нҷңм„ұнҷ”н•ҳм„ёмҡ”. л“ңлһҳк·ён•ҳм—¬ мҲңм„ңлҘј ліҖкІҪн•ҳкұ°лӮҳ мң„лЎң мқҙлҸҷ л°Ҹ м•„лһҳлЎң мқҙлҸҷ лҸҷмһ‘мқ„ мӮ¬мҡ©н•ҳм„ёмҡ”."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Aktivieren, um diesen Arbeitsbereich zu fokussieren. Ziehen zum Umordnen oder verwenden Sie die Aktionen 'Nach oben' und 'Nach unten'."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Activa para enfocar este espacio de trabajo. Arrastra para reordenar, o usa las acciones Mover hacia arriba y Mover hacia abajo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Activez pour accГ©der Г  cet espace de travail. Glissez pour rГ©ordonner, ou utilisez les actions DГ©placer vers le haut et DГ©placer vers le bas."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Attiva per portare il focus su questa area di lavoro. Trascina per riordinare oppure usa le azioni Sposta in alto e Sposta in basso."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Aktiver for at fokusere dette arbejdsomrГҘde. TrГҰk for at omarrangere, eller brug handlingerne Flyt op og Flyt ned."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Aktywuj, aby ustawiДҮ fokus na tej przestrzeni roboczej. PrzeciД…gnij, aby zmieniДҮ kolejnoЕӣДҮ, lub uЕјyj akcji PrzenieЕӣ w gГіrДҷ i PrzenieЕӣ w dГіЕӮ."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "РҗРәСӮРёРІРёСҖСғР№СӮРө РҙР»СҸ РҝРөСҖРөС…РҫРҙР° Рә СҚСӮРҫРјСғ СҖР°РұРҫСҮРөРјСғ РҝСҖРҫСҒСӮСҖР°РҪСҒСӮРІСғ. РҹРөСҖРөСӮР°СүРёСӮРө РҙР»СҸ РёР·РјРөРҪРөРҪРёСҸ РҝРҫСҖСҸРҙРәР° РёР»Рё РёСҒРҝРҫР»СҢР·СғР№СӮРө РҙРөР№СҒСӮРІРёСҸ В«РҹРөСҖРөРјРөСҒСӮРёСӮСҢ РІРІРөСҖС…В» Рё В«РҹРөСҖРөРјРөСҒСӮРёСӮСҢ РІРҪРёР·В»."
          }
        },
        "bs": {
          "stringUnit": {
            "state": "translated",
            "value": "Aktivirajte za fokusiranje ovog radnog prostora. Prevucite za prerasporeД‘ivanje ili koristite akcije Pomjeri gore i Pomjeri dolje."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "ЩҒШ№Щ‘Щ„ Щ„Щ„ШӘШұЩғЩҠШІ Ш№Щ„Щү Щ…ШіШ§ШӯШ© Ш§Щ„Ш№Щ…Щ„ ЩҮШ°ЩҮ. Ш§ШіШӯШЁ Щ„ШҘШ№Ш§ШҜШ© Ш§Щ„ШӘШұШӘЩҠШЁШҢ ШЈЩҲ Ш§ШіШӘШ®ШҜЩ… ШҘШ¬ШұШ§ШЎШ§ШӘ ЩҶЩӮЩ„ Щ„Щ„ШЈШ№Щ„Щү ЩҲЩҶЩӮЩ„ Щ„Щ„ШЈШіЩҒЩ„."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Aktiver for ГҘ fokusere dette arbeidsomrГҘdet. Dra for ГҘ omorganisere, eller bruk Flytt opp og Flytt ned."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Ative para focar nesta ГЎrea de trabalho. Arraste para reordenar ou use as aГ§Гөes Mover para Cima e Mover para Baixo."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "а№Җаёӣаёҙаё”а№ғаёҠа№үаёҮаёІаёҷа№Җаёһаё·а№Ҳаёӯа№ӮаёҹаёҒаёұаёӘа№Җаё§аёҙаёЈа№ҢаёҒаёӘа№ҖаёӣаёӢаёҷаёөа№ү аёҘаёІаёҒа№Җаёһаё·а№ҲаёӯаёҲаёұаё”а№ҖаёЈаёөаёўаёҮа№ғаё«аёЎа№Ҳ аё«аёЈаё·аёӯа№ғаёҠа№үаёҒаёІаёЈаёҒаёЈаё°аё—аёіа№ҖаёҘаё·а№ҲаёӯаёҷаёӮаё¶а№үаёҷа№ҒаёҘаё°а№ҖаёҘаё·а№ҲаёӯаёҷаёҘаёҮ"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bu Г§alДұЕҹma alanДұna odaklanmak iГ§in etkinleЕҹtirin. Yeniden sДұralamak iГ§in sГјrГјkleyin veya YukarДұ TaЕҹДұ ve AЕҹaДҹДұ TaЕҹДұ eylemlerini kullanДұn."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "РҗРәСӮРёРІСғР№СӮРө, СүРҫРұ СҒС„РҫРәСғСҒСғРІР°СӮРё СҶСҺ СҖРҫРұРҫСҮСғ РҫРұР»Р°СҒСӮСҢ. РҹРөСҖРөСӮСҸРіРҪС–СӮСҢ РҙР»СҸ Р·РјС–РҪРё РҝРҫСҖСҸРҙРәСғ Р°РұРҫ РІРёРәРҫСҖРёСҒСӮРҫРІСғР№СӮРө РҙС–С— В«РҹРөСҖРөРјС–СҒСӮРёСӮРё РІРіРҫСҖСғВ» СӮР° В«РҹРөСҖРөРјС–СҒСӮРёСӮРё РІРҪРёР·В»."
          }
        }
      }
    },
