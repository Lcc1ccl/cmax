          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "е…ҒиЁұд»»дҪ•жң¬ж©ҹзЁӢеәҸе’ҢдҪҝз”ЁиҖ…йҖЈз·ҡпјҢз„ЎйңҖй©—иӯүгҖӮдёҚе®үе…ЁгҖӮ"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "мқёмҰқ м—Ҷмқҙ лӘЁл“  лЎңм»¬ н”„лЎңм„ёмҠӨ л°Ҹ мӮ¬мҡ©мһҗмқҳ м—°кІ°мқ„ н—Ҳмҡ©н•©лӢҲлӢӨ. м•Ҳм „н•ҳм§Җ м•ҠмҠөлӢҲлӢӨ."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Jeden lokalen Prozess und Benutzer ohne Authentifizierung verbinden lassen. Unsicher."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Permitir que cualquier proceso y usuario local se conecte sin autenticaciГіn. Inseguro."
