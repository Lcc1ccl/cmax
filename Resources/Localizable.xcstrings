        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Aviso: O acesso aberto total torna o socket de controle legГӯvel/gravГЎvel por todos neste Mac e desativa verificaГ§Гөes de autenticaГ§ГЈo. Use apenas para depuraГ§ГЈo local."
