        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Р—Р°РәСҖС–РҝР»РөРҪС– СҖРҫРұРҫСҮС– РҫРұР»Р°СҒСӮС– РҪРө РјРҫР¶РҪР° Р·Р°РәСҖРёСӮРё, РҝРҫРәРё РІРҫРҪРё Р·Р°РәСҖС–РҝР»РөРҪС–. РЎРҝРҫСҮР°СӮРәСғ РІС–РҙРәСҖС–РҝС–СӮСҢ СҖРҫРұРҫСҮСғ РҫРұР»Р°СҒСӮСҢ."
