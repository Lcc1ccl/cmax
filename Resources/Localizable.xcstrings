        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ дҪҝз”ЁзәҜ HTTP иҝһжҺҘпјҢзҪ‘з»ңдёҠзҡ„жөҒйҮҸеҸҜиғҪиў«иҜ»еҸ–жҲ–дҝ®ж”№гҖӮ\n\nиҜ·еңЁй»ҳи®ӨжөҸи§ҲеҷЁдёӯжү“ејҖжӯӨ URLпјҢжҲ–еңЁ cmux дёӯз»§з»ӯи®ҝй—®гҖӮ"
