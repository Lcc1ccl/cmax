        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "Щ„Щ… ЩҠШӘЩ… ШӘШ№ЩҠЩҠЩҶ ЩғЩ„Щ…Ш© Щ…ШұЩҲШұ. ШіЩҠШӘЩ… ШӯШёШұ Ш§Щ„Ш№Щ…Щ„Ш§ШЎ Ш§Щ„Ш®Ш§ШұШ¬ЩҠЩҠЩҶ ШӯШӘЩү ЩҠШӘЩ… ШӘЩғЩҲЩҠЩҶ ЩҲШ§ШӯШҜШ©."
          }
