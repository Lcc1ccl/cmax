        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "аёӯаёҷаёёаёҚаёІаё•а№ғаё«а№үаёҒаёЈаё°аёҡаё§аёҷаёҒаёІаёЈа№ғаёҷа№Җаё„аёЈаё·а№ҲаёӯаёҮа№ҒаёҘаё°аёңаё№а№үа№ғаёҠа№үаё—аёёаёҒаё„аёҷа№ҖаёҠаё·а№ҲаёӯаёЎаё•а№Ҳаёӯа№Ӯаё”аёўа№„аёЎа№Ҳаё•а№үаёӯаёҮаёўаё·аёҷаёўаёұаёҷаё•аёұаё§аё•аёҷ а№„аёЎа№ҲаёӣаёҘаёӯаё”аё аёұаёў"
