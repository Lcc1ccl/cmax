        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "ШӘШӯШөЩ„ ЩғЩ„ Щ…ШіШ§ШӯШ© Ш№Щ…Щ„ Ш№Щ„Щү Щ…ШӘШәЩҠШұШ§ШӘ Ш§Щ„ШЁЩҠШҰШ© CMUX_PORT ЩҲ CMUX_PORT_END Щ…Ш№ ЩҶШ·Ш§ЩӮ Щ…ЩҶШ§ЩҒШ° Щ…Ш®ШөШө. ШӘШұШ« Ш§Щ„Ш·ШұЩҒЩҠШ§ШӘ Ш§Щ„Ш¬ШҜЩҠШҜШ© ЩҮШ°ЩҮ Ш§Щ„ЩӮЩҠЩ…."
