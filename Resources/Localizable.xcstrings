        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "РҹР°СҖРҫР»СҢ РҪРө СғСҒСӮР°РҪРҫРІР»РөРҪ. Р’РҪРөСҲРҪРёРө РәР»РёРөРҪСӮСӢ РұСғРҙСғСӮ Р·Р°РұР»РҫРәРёСҖРҫРІР°РҪСӢ, РҝРҫРәР° РҫРҪ РҪРө РұСғРҙРөСӮ РҪР°СҒСӮСҖРҫРөРҪ."
