        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "иӯҰе‘Ҡгғ—гғӯгғігғ—гғҲгҒӘгҒ—гҒ§cmuxгҒ§й–ӢгҒ‘гӮӢHTTPпјҲйқһHTTPSпјүгғӣгӮ№гғҲгӮ’еҲ¶еҫЎгҒ—гҒҫгҒҷгҖӮгғҮгғ•гӮ©гғ«гғҲгҒ«гҒҜlocalhostгҖҒ127.0.0.1гҖҒ::1гҖҒ0.0.0.0гҖҒ*.localtest.meгҒҢеҗ«гҒҫгӮҢгҒҫгҒҷгҖӮ"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "жҺ§еҲ¶е“Әдәӣ HTTPпјҲйқһ HTTPSпјүдё»жңәеҸҜд»ҘеңЁ cmux дёӯжү“ејҖиҖҢдёҚжҳҫзӨәиӯҰе‘ҠжҸҗзӨәгҖӮй»ҳи®ӨеҢ…жӢ¬ localhostгҖҒ127.0.0.1гҖҒ::1гҖҒ0.0.0.0 е’Ң *.localtest.meгҖӮ"
