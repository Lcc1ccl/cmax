        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "РЈРҝСҖР°РІР»СҸРөСӮ РҙРҫСҒСӮСғРҝРҫРј Рә Р»РҫРәР°Р»СҢРҪРҫРјСғ Unix-СҒРҫРәРөСӮСғ РҙР»СҸ РҝСҖРҫРіСҖР°РјРјРҪРҫРіРҫ СғРҝСҖР°РІР»РөРҪРёСҸ. Р’СӢРұРөСҖРёСӮРө СҖРөР¶РёРј, СҒРҫРҫСӮРІРөСӮСҒСӮРІСғСҺСүРёР№ РІР°СҲРөР№ РјРҫРҙРөР»Рё СғРіСҖРҫР·."
