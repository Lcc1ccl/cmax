        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "гғ—гғӯгӮ°гғ©гғ гҒ«гӮҲгӮӢеҲ¶еҫЎгҒ®гҒҹгӮҒгҒ®гғӯгғјгӮ«гғ«Unix socketгҒёгҒ®гӮўгӮҜгӮ»гӮ№гӮ’еҲ¶еҫЎгҒ—гҒҫгҒҷгҖӮи„…еЁҒгғўгғҮгғ«гҒ«еҗҲгҒЈгҒҹгғўгғјгғүгӮ’йҒёжҠһгҒ—гҒҰгҒҸгҒ гҒ•гҒ„гҖӮ"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "жҺ§еҲ¶жң¬ең° Unix еҘ—жҺҘеӯ—зҡ„и®ҝй—®жқғйҷҗпјҢз”ЁдәҺзЁӢеәҸеҢ–жҺ§еҲ¶гҖӮиҜ·йҖүжӢ©дёҺжӮЁзҡ„е®үе…ЁйңҖжұӮеҢ№й…Қзҡ„жЁЎејҸгҖӮ"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "жҺ§еҲ¶жң¬ж©ҹ Unix Socket зҡ„зЁӢејҸеҢ–жҺ§еҲ¶еӯҳеҸ–гҖӮйҒёж“Үз¬ҰеҗҲжӮЁе®үе…ЁйңҖжұӮзҡ„жЁЎејҸгҖӮ"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "н”„лЎңк·ёлһҳл°Қ л°©мӢқ м ңм–ҙлҘј мң„н•ң лЎңм»¬ Unix мҶҢмј“ м ‘к·јмқ„ м ңм–ҙн•©лӢҲлӢӨ. ліҙм•Ҳ лӘЁлҚём—җ л§һлҠ” лӘЁл“ңлҘј м„ нғқн•ҳм„ёмҡ”."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Steuert den Zugriff auf den lokalen Unix-Socket fГјr programmatische Steuerung. WГӨhlen Sie einen Modus, der Ihrem Bedrohungsmodell entspricht."
          }
