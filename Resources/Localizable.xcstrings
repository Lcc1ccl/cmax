    "settings.automation.claudeCode.note": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "When enabled, cmux wraps the claude command to inject session tracking and notification hooks. Disable if you prefer to manage Claude Code hooks yourself."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "жңүеҠ№гҒ«гҒҷгӮӢгҒЁгҖҒcmuxгҒҜclaudeгӮігғһгғігғүгӮ’гғ©гғғгғ—гҒ—гҒҰгӮ»гғғгӮ·гғ§гғіиҝҪи·ЎгҒЁйҖҡзҹҘгғ•гғғгӮҜгӮ’жҢҝе…ҘгҒ—гҒҫгҒҷгҖӮClaude CodeгҒ®гғ•гғғгӮҜгӮ’иҮӘеҲҶгҒ§з®ЎзҗҶгҒҷгӮӢе ҙеҗҲгҒҜз„ЎеҠ№гҒ«гҒ—гҒҰгҒҸгҒ гҒ•гҒ„гҖӮ"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "еҗҜз”ЁеҗҺпјҢcmux дјҡеҢ…иЈ… claude е‘Ҫд»Өд»ҘжіЁе…ҘдјҡиҜқи·ҹиёӘе’ҢйҖҡзҹҘй’©еӯҗгҖӮеҰӮжһңжӮЁеёҢжңӣиҮӘиЎҢз®ЎзҗҶ Claude Code й’©еӯҗпјҢиҜ·зҰҒз”ЁжӯӨйҖүйЎ№гҖӮ"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "е•ҹз”ЁеҫҢпјҢcmux жңғеҢ…иЈқ claude жҢҮд»Өд»ҘжіЁе…Ҙе·ҘдҪңйҡҺж®өиҝҪи№Өе’ҢйҖҡзҹҘжҺӣйүӨгҖӮеҰӮжһңжӮЁеҒҸеҘҪиҮӘиЎҢз®ЎзҗҶ Claude Code жҺӣйүӨпјҢи«ӢеҒңз”ЁжӯӨйҒёй …гҖӮ"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "нҷңм„ұнҷ”н•ҳл©ҙ cmuxк°Җ claude лӘ…л №мқ„ лһҳн•‘н•ҳм—¬ м„ём…ҳ м¶”м Ғ л°Ҹ м•ҢлҰј нӣ…мқ„ мӮҪмһ…н•©лӢҲлӢӨ. Claude Code нӣ…мқ„ м§Ғм ‘ кҙҖлҰ¬н•ҳл Өл©ҙ л№„нҷңм„ұнҷ”н•ҳм„ёмҡ”."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wenn aktiviert, umhГјllt cmux den claude-Befehl, um Sitzungsverfolgung und Benachrichtigungs-Hooks einzufГјgen. Deaktivieren Sie dies, wenn Sie Claude Code-Hooks selbst verwalten mГ¶chten."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Cuando estГЎ activado, cmux envuelve el comando claude para inyectar seguimiento de sesiГіn y hooks de notificaciГіn. Desactiva si prefieres gestionar los hooks de Claude Code tГә mismo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorsque cette option est activГ©e, cmux encapsule la commande claude pour injecter le suivi de session et les hooks de notification. DГ©sactivez si vous prГ©fГ©rez gГ©rer les hooks Claude Code vous-mГӘme."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Quando abilitato, cmux avvolge il comando claude per iniettare il tracciamento della sessione e gli hook di notifica. Disabilita se preferisci gestire gli hook di Claude Code manualmente."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "NГҘr aktiveret, wrapper cmux claude-kommandoen for at injicere sessionssporing og notifikationshooks. Deaktiver, hvis du foretrГҰkker at administrere Claude Code-hooks selv."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Po wЕӮД…czeniu cmux opakowuje polecenie claude, aby wstrzyknД…ДҮ Еӣledzenie sesji i hooki powiadomieЕ„. WyЕӮД…cz, jeЕӣli wolisz samodzielnie zarzД…dzaДҮ hookami Claude Code."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "РҹСҖРё РІРәР»СҺСҮРөРҪРёРё cmux РҫРұРҫСҖР°СҮРёРІР°РөСӮ РәРҫРјР°РҪРҙСғ claude РҙР»СҸ РҫСӮСҒР»РөР¶РёРІР°РҪРёСҸ СҒРөР°РҪСҒРҫРІ Рё СғРІРөРҙРҫРјР»РөРҪРёР№. РһСӮРәР»СҺСҮРёСӮРө, РөСҒР»Рё РҝСҖРөРҙРҝРҫСҮРёСӮР°РөСӮРө СғРҝСҖР°РІР»СҸСӮСҢ С…СғРәР°РјРё Claude Code СҒР°РјРҫСҒСӮРҫСҸСӮРөР»СҢРҪРҫ."
          }
        },
        "bs": {
          "stringUnit": {
            "state": "translated",
            "value": "Kada je omoguДҮeno, cmux omotava naredbu claude kako bi ubacio praДҮenje sesije i zakaДҚke za obavjeЕЎtenja. OnemoguДҮite ako preferirate sami upravljati Claude Code zakaДҚkama."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "Ш№ЩҶШҜ Ш§Щ„ШӘЩҒШ№ЩҠЩ„ШҢ ЩҠШәЩ„Щ‘ЩҒ cmux ШЈЩ…Шұ claude Щ„ШӯЩӮЩҶ ШӘШӘШЁШ№ Ш§Щ„Ш¬Щ„ШіШ© ЩҲШ®Ш·Ш§ЩҒШ§ШӘ Ш§Щ„ШҘШҙШ№Ш§ШұШ§ШӘ. ЩӮЩ… ШЁШ§Щ„ШӘШ№Ш·ЩҠЩ„ ШҘШ°Ш§ ЩғЩҶШӘ ШӘЩҒШ¶Щ„ ШҘШҜШ§ШұШ© Ш®Ш·Ш§ЩҒШ§ШӘ Claude Code ШЁЩҶЩҒШіЩғ."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "NГҘr aktivert, pakker cmux inn claude-kommandoen for ГҘ injisere sesjonssporing og varslingsmekanismer. Deaktiver hvis du foretrekker ГҘ hГҘndtere Claude Code-mekanismer selv."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Quando ativado, o cmux encapsula o comando claude para injetar rastreamento de sessГЈo e hooks de notificaГ§ГЈo. Desative se preferir gerenciar os hooks do Claude Code vocГӘ mesmo."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
