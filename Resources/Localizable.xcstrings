        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "РҰРө РІРёРјРёРәР°С” РҝРөСҖРөРІС–СҖРәСғ РҝРҫС…РҫРҙР¶РөРҪРҪСҸ СӮР° РҝР°СҖРҫР»СҸ С– РІС–РҙРәСҖРёРІР°С” СҒРҫРәРөСӮ РҙР»СҸ РІСҒС–С… Р»РҫРәР°Р»СҢРҪРёС… РәРҫСҖРёСҒСӮСғРІР°СҮС–РІ. Р’РјРёРәР°Р№СӮРө Р»РёСҲРө СҸРәСүРҫ СҖРҫР·СғРјС–С”СӮРө СҖРёР·РёРәРё."
