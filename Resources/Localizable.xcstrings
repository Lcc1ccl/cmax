        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Un espace de travail portant ce nom existe dГ©jГ . Le fermer et en crГ©er un nouveau ?"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Esiste giГ  un'area di lavoro con questo nome. Chiuderla e crearne una nuova?"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "гҒ“гҒ®еҗҚеүҚгҒ®гғҜгғјгӮҜгӮ№гғҡгғјгӮ№гҒҜж—ўгҒ«еӯҳеңЁгҒ—гҒҫгҒҷгҖӮй–үгҒҳгҒҰж–°гҒ—гҒҸдҪңжҲҗгҒ—гҒҫгҒҷгҒӢпјҹ"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "к°ҷмқҖ мқҙлҰ„мқҳ мӣҢнҒ¬мҠӨнҺҳмқҙмҠӨк°Җ мқҙлҜё мһҲмҠөлӢҲлӢӨ. лӢ«кі  мғҲлЎң л§Ңл“ңмӢңкІ мҠөлӢҲк№Ң?"
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Et arbeidsomrГҘde med dette navnet finnes allerede. Lukke det og opprette et nytt?"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "PrzestrzeЕ„ robocza o tej nazwie juЕј istnieje. ZamknД…ДҮ jД… i utworzyДҮ nowД…?"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Um espaГ§o de trabalho com este nome jГЎ existe. Fechar e criar um novo?"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Р Р°РұРҫСҮР°СҸ РҫРұР»Р°СҒСӮСҢ СҒ СӮР°РәРёРј РёРјРөРҪРөРј СғР¶Рө СҒСғСүРөСҒСӮРІСғРөСӮ. Р—Р°РәСҖСӢСӮСҢ РөС‘ Рё СҒРҫР·РҙР°СӮСҢ РҪРҫРІСғСҺ?"
          }
        },
        "th": {
