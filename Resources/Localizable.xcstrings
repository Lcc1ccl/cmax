        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "Ш§Щ„ШіЩ…Ш§Шӯ Щ„ШЈЩҠ Ш№Щ…Щ„ЩҠШ© ЩҲЩ…ШіШӘШ®ШҜЩ… Щ…ШӯЩ„ЩҠ ШЁШ§Щ„Ш§ШӘШөШ§Щ„ ШЁШҜЩҲЩҶ Щ…ШөШ§ШҜЩӮШ©. ШәЩҠШұ ШўЩ…ЩҶ."
