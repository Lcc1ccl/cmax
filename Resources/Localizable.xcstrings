        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "РҹР°СҖРҫР»СҢ РҪРө РІСҒСӮР°РҪРҫРІР»РөРҪРҫ. Р—РҫРІРҪС–СҲРҪС– РәР»С–С”РҪСӮРё РұСғРҙСғСӮСҢ Р·Р°РұР»РҫРәРҫРІР°РҪС–, РҝРҫРәРё Р№РҫРіРҫ РҪРө РҪР°Р»Р°СҲСӮСғРІР°СӮРё."
