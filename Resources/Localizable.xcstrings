    "settings.workspaceColors.paletteNote": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Customize the workspace color palette used by Sidebar > Workspace Color. \"Choose Custom Color...\" entries are persisted below."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "гӮөгӮӨгғүгғҗгғј > гғҜгғјгӮҜгӮ№гғҡгғјгӮ№гӮ«гғ©гғјгҒ§дҪҝз”ЁгҒҷгӮӢгӮ«гғ©гғјгғ‘гғ¬гғғгғҲгӮ’гӮ«гӮ№гӮҝгғһгӮӨгӮәгҒ§гҒҚгҒҫгҒҷгҖӮгҖҢгӮ«гӮ№гӮҝгғ гӮ«гғ©гғјгӮ’йҒёжҠһвҖҰгҖҚгҒ®гӮЁгғігғҲгғӘгҒҜд»ҘдёӢгҒ«дҝқеӯҳгҒ•гӮҢгҒҫгҒҷгҖӮ"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "иҮӘе®ҡд№үгҖҢдҫ§иҫ№ж Ҹ > е·ҘдҪңеҢәйўңиүІгҖҚдёӯдҪҝз”Ёзҡ„е·ҘдҪңеҢәи°ғиүІжқҝгҖӮгҖҢйҖүеҸ–иҮӘе®ҡд№үйўңиүІ...гҖҚзҡ„жқЎзӣ®е°ҶдҝқеӯҳеңЁдёӢж–№гҖӮ"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "иҮӘиЁӮеҒҙйӮҠж¬„ > е·ҘдҪңеҚҖйЎҸиүІдҪҝз”Ёзҡ„иүІжқҝгҖӮгҖҢйҒёж“ҮиҮӘиЁӮйЎҸиүІ...гҖҚзҡ„й …зӣ®жңғдҝқеӯҳеңЁдёӢж–№гҖӮ"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "мӮ¬мқҙл“ңл°” > мһ‘м—… кіөк°„ мғүмғҒм—җм„ң мӮ¬мҡ©н•ҳлҠ” мһ‘м—… кіөк°„ мғүмғҒ нҢ”л ҲнҠёлҘј мӮ¬мҡ©мһҗ м§Җм •н•©лӢҲлӢӨ. \"мӮ¬мҡ©мһҗ м§Җм • мғүмғҒ м„ нғқ...\" н•ӯлӘ©мқҖ м•„лһҳм—җ м ҖмһҘлҗ©лӢҲлӢӨ."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Passen Sie die Arbeitsbereichs-Farbpalette an, die unter Seitenleiste > Arbeitsbereichsfarbe verwendet wird. EintrГӨge unter 'Eigene Farbe wГӨhlen ...' werden unten gespeichert."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Personaliza la paleta de colores de espacios de trabajo usada en Barra lateral > Color del espacio de trabajo. Las entradas de \"Elegir color personalizadoвҖҰ\" se guardan a continuaciГіn."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Personnalisez la palette de couleurs utilisГ©e par Barre latГ©rale > Couleur de l'espace de travail. Les entrГ©es В« Choisir une couleur personnalisГ©e... В» sont enregistrГ©es ci-dessous."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Personalizza la palette di colori utilizzata da Barra laterale > Colore area di lavoro. Le voci \"Scegli colore personalizzato...\" vengono salvate qui sotto."
