        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ дҪҝз”ЁжңӘеҠ еҜҶзҡ„ HTTPпјҢз¶Іи·ҜдёҠзҡ„жөҒйҮҸеҸҜиғҪиў«и®ҖеҸ–жҲ–з«„ж”№гҖӮ\n\nеңЁжӮЁзҡ„й җиЁӯзҖҸиҰҪеҷЁдёӯй–Ӣе•ҹжӯӨ URLпјҢжҲ–еңЁ cmux дёӯз№јзәҢгҖӮ"
