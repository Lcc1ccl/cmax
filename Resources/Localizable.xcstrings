    "settings.automation.openAccess.dialog.message": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This disables ancestry and password checks and opens the socket to all local users. Only enable when you understand the risk."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "гҒ“гӮҢгҒ«гӮҲгӮҠгҖҒзҘ–е…Ҳгғ—гғӯгӮ»гӮ№гғҒгӮ§гғғгӮҜгҒЁгғ‘гӮ№гғҜгғјгғүгғҒгӮ§гғғгӮҜгҒҢз„ЎеҠ№гҒ«гҒӘгӮҠгҖҒгҒҷгҒ№гҒҰгҒ®гғӯгғјгӮ«гғ«гғҰгғјгӮ¶гғјгҒ«гӮҪгӮұгғғгғҲгҒҢе…¬й–ӢгҒ•гӮҢгҒҫгҒҷгҖӮгғӘгӮ№гӮҜгӮ’зҗҶи§ЈгҒ—гҒҹдёҠгҒ§жңүеҠ№гҒ«гҒ—гҒҰгҒҸгҒ гҒ•гҒ„гҖӮ"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "иҝҷе°ҶзҰҒз”ЁзҘ–е…Ҳе’ҢеҜҶз ҒжЈҖжҹҘпјҢе№¶еҗ‘жүҖжңүжң¬ең°з”ЁжҲ·ејҖж”ҫеҘ—жҺҘеӯ—гҖӮиҜ·зЎ®дҝқжӮЁдәҶи§Је…¶дёӯзҡ„йЈҺйҷ©еҗҺеҶҚеҗҜз”ЁгҖӮ"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "йҖҷе°ҮеҒңз”ЁдҫҶжәҗй©—иӯүе’ҢеҜҶзўјжӘўжҹҘпјҢдёҰе°Ү Socket й–Ӣж”ҫзөҰжүҖжңүжң¬ж©ҹдҪҝз”ЁиҖ…гҖӮи«ӢзўәиӘҚжӮЁдәҶи§ЈйўЁйҡӘеҫҢеҶҚе•ҹз”ЁгҖӮ"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "мқҙ м„Өм •мқҖ м¶ңмІҳ нҷ•мқё л°Ҹ л№„л°ҖлІҲнҳё кІҖмӮ¬лҘј л№„нҷңм„ұнҷ”н•ҳкі  лӘЁл“  лЎңм»¬ мӮ¬мҡ©мһҗм—җкІҢ мҶҢмј“мқ„ к°ңл°©н•©лӢҲлӢӨ. мң„н—ҳмқ„ мқҙн•ҙн•ң кІҪмҡ°м—җл§Ң нҷңм„ұнҷ”н•ҳм„ёмҡ”."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dies deaktiviert Abstammungs- und PasswortprГјfungen und Г¶ffnet den Socket fГјr alle lokalen Benutzer. Aktivieren Sie dies nur, wenn Sie das Risiko verstehen."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Esto desactiva las verificaciones de ascendencia y contraseГұa, y abre el socket a todos los usuarios locales. Activa solo si comprendes el riesgo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Cela dГ©sactive les vГ©rifications de parentГ© et de mot de passe et ouvre le socket Г  tous les utilisateurs locaux. N'activez que si vous comprenez les risques."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Questa operazione disabilita i controlli di discendenza e password e apre il socket a tutti gli utenti locali. Abilita solo se comprendi il rischio."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Dette deaktiverer herkomst- og adgangskodekontrol og ГҘbner socketen for alle lokale brugere. Aktiver kun, nГҘr du forstГҘr risikoen."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "To wyЕӮД…cza sprawdzanie pochodzenia i hasЕӮa oraz otwiera gniazdo dla wszystkich lokalnych uЕјytkownikГіw. WЕӮД…czaj tylko wtedy, gdy rozumiesz ryzyko."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "РӯСӮРҫ РҫСӮРәР»СҺСҮР°РөСӮ РҝСҖРҫРІРөСҖРәСғ РҝСҖРҫРёСҒС…РҫР¶РҙРөРҪРёСҸ Рё РҝР°СҖРҫР»СҸ Рё РҫСӮРәСҖСӢРІР°РөСӮ СҒРҫРәРөСӮ РҙР»СҸ РІСҒРөС… Р»РҫРәР°Р»СҢРҪСӢС… РҝРҫР»СҢР·РҫРІР°СӮРөР»РөР№. Р’РәР»СҺСҮР°Р№СӮРө СӮРҫР»СҢРәРҫ РөСҒР»Рё РҝРҫРҪРёРјР°РөСӮРө СҖРёСҒРәРё."
          }
        },
        "bs": {
          "stringUnit": {
            "state": "translated",
            "value": "Ovo onemoguДҮava provjere porijekla i lozinke i otvara utiДҚnicu svim lokalnim korisnicima. OmoguДҮite samo kada razumijete rizik."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "ЩҠШӨШҜЩҠ ЩҮШ°Ш§ ШҘЩ„Щү ШӘШ№Ш·ЩҠЩ„ ЩҒШӯЩҲШөШ§ШӘ Ш§Щ„ЩҶШіШЁ ЩҲЩғЩ„Щ…Ш© Ш§Щ„Щ…ШұЩҲШұ ЩҲЩҠЩҒШӘШӯ Ш§Щ„Щ…ЩӮШЁШі Щ„Ш¬Щ…ЩҠШ№ Ш§Щ„Щ…ШіШӘШ®ШҜЩ…ЩҠЩҶ Ш§Щ„Щ…ШӯЩ„ЩҠЩҠЩҶ. ЩӮЩ… ШЁШ§Щ„ШӘЩҒШ№ЩҠЩ„ ЩҒЩӮШ· Ш№ЩҶШҜЩ…Ш§ ШӘЩҒЩҮЩ… Ш§Щ„Щ…Ш®Ш§Ш·Шұ."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Dette deaktiverer opphavs- og passordkontroller og ГҘpner socketen for alle lokale brukere. Aktiver bare nГҘr du forstГҘr risikoen."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Isto desativa verificaГ§Гөes de ancestralidade e senha e abre o socket para todos os usuГЎrios locais. Ative somente quando entender os riscos."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "аёҒаёІаёЈаё”аёіа№ҖаёҷаёҙаёҷаёҒаёІаёЈаёҷаёөа№үаёҲаё°аёӣаёҙаё”а№ғаёҠа№үаёҮаёІаёҷаёҒаёІаёЈаё•аёЈаё§аёҲаёӘаёӯаёҡаёӘаёІаёўаёӘаё·аёҡаё—аёӯаё”а№ҒаёҘаё°аёЈаё«аёұаёӘаёңа№ҲаёІаёҷ а№ҒаёҘаё°а№Җаёӣаёҙаё”аёӢа№ҮаёӯаёҒа№ҖаёҒа№Үаё•а№ғаё«а№үаёңаё№а№үа№ғаёҠа№үа№ғаёҷа№Җаё„аёЈаё·а№ҲаёӯаёҮаё—аёёаёҒаё„аёҷ а№Җаёӣаёҙаё”а№ғаёҠа№үаёҮаёІаёҷа№ҖаёүаёһаёІаё°а№ҖаёЎаё·а№Ҳаёӯаё„аёёаё“а№ҖаёӮа№үаёІа№ғаёҲаё„аё§аёІаёЎа№ҖаёӘаёөа№ҲаёўаёҮ"
