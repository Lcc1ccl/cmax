    "settings.app.keepWindowOpenWhenClosingLastProjectWorkspace.subtitleOn": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "When closing the last workspace for a project in the current window, cmux creates a new workspace for that same project. Tmp workspaces always keep their current replacement behavior."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "зҸҫеңЁгҒ®гӮҰгӮЈгғігғүгӮҰеҶ…гҒ§гғ—гғӯгӮёгӮ§гӮҜгғҲгҒ®жңҖеҫҢгҒ®гғҜгғјгӮҜгӮ№гғҡгғјгӮ№гӮ’й–үгҒҳгӮӢгҒЁгҖҒcmux гҒҜеҗҢгҒҳгғ—гғӯгӮёгӮ§гӮҜгғҲз”ЁгҒ®ж–°гҒ—гҒ„гғҜгғјгӮҜгӮ№гғҡгғјгӮ№гӮ’дҪңжҲҗгҒ—гҒҫгҒҷгҖӮtmp гғҜгғјгӮҜгӮ№гғҡгғјгӮ№гҒҜеёёгҒ«зҸҫеңЁгҒ®зҪ®гҒҚжҸӣгҒҲеӢ•дҪңгӮ’з¶ӯжҢҒгҒ—гҒҫгҒҷгҖӮ"
          }
        }
      }
    },
    "settings.app.keepWindowOpenWhenClosingLastProjectWorkspace.subtitleOff": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "When closing the last workspace for a project in the current window, cmux keeps the existing close behavior. Tmp workspaces always keep their current replacement behavior."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "зҸҫеңЁгҒ®гӮҰгӮЈгғігғүгӮҰеҶ…гҒ§гғ—гғӯгӮёгӮ§гӮҜгғҲгҒ®жңҖеҫҢгҒ®гғҜгғјгӮҜгӮ№гғҡгғјгӮ№гӮ’й–үгҒҳгӮӢгҒЁгҖҒcmux гҒҜж—ўеӯҳгҒ®гӮҜгғӯгғјгӮәеӢ•дҪңгӮ’з¶ӯжҢҒгҒ—гҒҫгҒҷгҖӮtmp гғҜгғјгӮҜгӮ№гғҡгғјгӮ№гҒҜеёёгҒ«зҸҫеңЁгҒ®зҪ®гҒҚжҸӣгҒҲеӢ•дҪңгӮ’з¶ӯжҢҒгҒ—гҒҫгҒҷгҖӮ"
          }
        }
      }
    }
  }
}
